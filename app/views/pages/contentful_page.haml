:ruby
  translation = @translation_used || {}
  page_title = translation['title'] || @page['slug']&.to_s&.tr('-', ' ')&.titleize || 'Page'
  page_title = "#{page_title} (DRAFT)" if @is_draft
  title page_title
  # description t('views.pages.contact._description')

  set_meta_tags og: {
    url: @og_url
  }

%main.mt-0
  %article
    = render 'topbar' do
      = page_title
    .container-xl.mt-4
      .row.justify-content-center
        .col-md-8
          - if @using_fallback
            %small.text-warning.mb-3.d-block (Displayed in en-GB)
          - if translation['content'].present?
            - content = translation['content'].to_s
            - if content.lstrip.start_with?('<')
              = sanitize(content, tags: %w[section h1 h2 h3 h4 h5 h6 p br ul ol li a strong em code pre span div img], attributes: %w[href target rel class style src alt width height loading decoding])
            - else
              = redcarpet(NewsArticleRenderer).render(content).html_safe
